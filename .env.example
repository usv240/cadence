# Keep preview and local development free and offline-first.
MOCK_MODE=1

# Required only when MOCK_MODE=0 in Production. Never expose these as NEXT_PUBLIC_* variables.
OPENAI_API_KEY=
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Optional OpenAI TTS defaults.
TTS_MODEL=gpt-4o-mini-tts
TTS_VOICE=marin
